# ===========================================================================
# API SERVER (Railway) — set semua ini di Railway > Variables
# ===========================================================================

# --- Database (Supabase) ---------------------------------------------------
# Pakai SESSION POOLER (port 5432), BUKAN Transaction Pooler (6543).
# Transaction pooler tidak mendukung prepared statement & session-level state
# yang dipakai connect-pg-simple.
# Supabase Dashboard > Project Settings > Database > Connection string > Session pooler
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# SSL dideteksi otomatis dari host. Override manual kalau perlu:
# DB_SSL=true
# DB_POOL_MAX=10

# --- Auth ------------------------------------------------------------------
# WAJIB di production. Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Umur session & bearer token (detik). Default 7 hari.
# TOKEN_TTL_SECONDS=604800

# --- CORS ------------------------------------------------------------------
# Origin FE yang diizinkan, pisah dengan koma. TANPA trailing slash.
CORS_ORIGINS=https://aina-scraper.vercel.app,http://localhost:5173

# Izinkan semua preview deployment *.vercel.app (praktis, tapi lebih longgar).
# ALLOW_VERCEL_PREVIEWS=true

# --- Cookie (OPSIONAL tapi SANGAT DISARANKAN) ------------------------------
# Set ini HANYA kalau FE & BE berbagi parent domain,
# misal app.aina.id (Vercel) + api.aina.id (Railway):
#   COOKIE_DOMAIN=.aina.id
# Efeknya: cookie jadi same-site (SameSite=Lax) -> tidak diblokir Safari/Brave.
# Kalau dikosongkan, cookie dipaksa SameSite=None dan auth bersandar pada
# bearer token (sudah otomatis di-handle FE).
# COOKIE_DOMAIN=

# --- Zona waktu ------------------------------------------------------------
# Menentukan batas "hari ini" untuk target harian & scheduler cron.
APP_TZ=Africa/Cairo

# --- Scheduler -------------------------------------------------------------
# Set "false" kalau kamu menjalankan lebih dari 1 replica (cegah job dobel).
# ENABLE_SCHEDULER=true

# Secret untuk POST /api/cron/trigger (scheduler eksternal).
# Kirim sebagai header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Integrasi knowledge_base AINA (WAJIB) ---------------------------------
# UUID penulis untuk artikel yang di-approve ke knowledge_base.
# Kolom author_id NOT NULL tanpa default -> tanpa ini SEMUA approve gagal.
# Ambil nilainya di Supabase SQL Editor:
#   SELECT author_id, count(*) FROM knowledge_base GROUP BY 1 ORDER BY 2 DESC;
SCRAPER_AUTHOR_ID=38a8f526-b1a7-47ef-9a04-ecc8b2b63f27

# Embedding artikel -> kolom vector(1536) di knowledge_base.
# Model WAJIB text-embedding-3-large, dimensi 1536 — sama persis dengan 312
# artikel AINA yang sudah ada. Model/dimensi berbeda = hasil pencarian kacau.
#
# Cukup SALAH SATU (OPENAI_API_KEY dipakai duluan kalau dua-duanya diisi):
#
#   OPENROUTER_API_KEY  -> lewat https://openrouter.ai/api/v1/embeddings
#                          (model: openai/text-embedding-3-large)
#                          Key yang sama juga dipakai untuk analisis & klasifikasi.
#   OPENAI_API_KEY      -> langsung ke https://api.openai.com/v1/embeddings
#
# Catatan: OpenRouter belum mendokumentasikan parameter `dimensions`, jadi bisa
# jadi ia mengembalikan 3072 dimensi. Kode menanganinya otomatis (potong ke 1536
# + L2-normalize). Karena text-embedding-3 dilatih dengan Matryoshka, hasilnya
# IDENTIK dengan dimensions=1536 — aman.
#
# Tanpa key sama sekali: artikel tetap masuk knowledge_base, tapi TIDAK muncul
# di pencarian AINA sampai embedding-nya diisi.
OPENAI_API_KEY=

# --- Integrasi AI / scraping (opsional) ------------------------------------
# Tanpa OPENROUTER_API_KEY, sistem otomatis fallback ke heuristik keyword.
OPENROUTER_API_KEY=
# Tanpa APIFY_API_TOKEN, endpoint /scrape/instagram balas 503.
APIFY_API_TOKEN=

# --- Lain-lain -------------------------------------------------------------
# PORT=3000            # diisi otomatis oleh Railway
# LOG_LEVEL=info
# BODY_LIMIT=15mb      # batas ukuran upload PDF (base64)
NODE_ENV=production


# ===========================================================================
# FRONTEND (Vercel) — set di Vercel > Settings > Environment Variables
# ===========================================================================
# URL API server. TANPA trailing slash, TANPA "/api" di belakang.
VITE_API_BASE_URL=https://aina-api.up.railway.app

# --- Deteksi duplikat -------------------------------------------------------
# Ambang cosine similarity (0..1) antara artikel baru vs knowledge_base.
#   DEDUPE_WARN   : >= ini -> tampilkan peringatan "ada yang mirip"
#   DEDUPE_STRONG : >= ini -> tandai "hampir pasti duplikat"
#
# ANGKA DEFAULT DI BAWAH BELUM DIKALIBRASI ke data kamu. Jalankan query
# kalibrasi di DEDUPE.md untuk melihat sebaran kemiripan 312 artikelmu,
# lalu sesuaikan.
# DEDUPE_WARN=0.84
# DEDUPE_STRONG=0.92

# --- Instagram (Apify) ------------------------------------------------------
# Actor yang menerima LINK POSTINGAN langsung (directUrls).
#
# JANGAN pakai apify/instagram-post-scraper — actor itu "username-in":
# inputnya field `username`, bukan link postingan. Itu penyebab error
# "username is required" (HTTP 422) yang muncul sebelumnya.
# APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper

# Berapa slide carousel yang di-OCR. Postingan Masisir sering infografis
# 5-10 slide; sebelumnya HANYA slide pertama yang dibaca, jadi sebagian besar
# isinya hilang.
# IG_MAX_OCR_SLIDES=5

# --- Rapikan dengan AI ------------------------------------------------------
# Fitur "Rapikan dengan AI" memakai OPENROUTER_API_KEY yang sama.
# Model bisa diganti lewat OPENROUTER_MODEL (default: google/gemini-2.5-flash).
#
# Cara kerjanya: sebelum menulis ulang, sistem MENGAMBIL 2 artikel asli dari
# knowledge_base pada kategori yang sama, lalu memakainya sebagai contoh gaya.
# Jadi hasilnya mengikuti gaya rumah AINA — bukan gaya karangan model.
#
# Tanpa OPENROUTER_API_KEY: teks hanya dibersihkan dari sampah scraping
# (navigasi, byline, "Baca juga", dll), tidak ditulis ulang. UI memberi tahu.

# --- Rapikan otomatis saat scrape -------------------------------------------
# Default AKTIF. Set "false" untuk mematikan secara global.
# Kontributor juga bisa mematikannya per-scrape lewat saklar di halaman Input.
#
# Teks scrape ASLI selalu disimpan di kolom scraper_drafts.raw_content, dan
# bisa dibandingkan lewat tab "Teks Asli" di editor draft. Jadi kalau AI
# diam-diam membuang biaya/alamat/syarat, masih bisa dicek.
# AUTO_FORMAT_ON_SCRAPE=true
